<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="단축번호 관리"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"
        android:textColor="#000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="15dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btn_select_speed_key"
            android:layout_width="85dp"
            android:layout_height="45dp"
            android:text="숫자선택▼"
            android:textSize="13sp"
            android:textColor="#333333"
            android:background="@drawable/bg_speed_dial_purple"
            android:padding="0dp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.AppCompat.Button.Borderless" />

        <EditText
            android:id="@+id/et_speed_search"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:layout_weight="1"
            android:hint="이름 또는 번호 검색"
            android:textSize="14sp"
            android:inputType="textVisiblePassword"
            android:background="@drawable/bg_speed_dial_purple"
            android:paddingHorizontal="12dp"
            android:layout_marginEnd="8dp"/>

        <Button
            android:id="@+id/btn_add_speed_dial"
            android:layout_width="60dp"
            android:layout_height="45dp"
            android:text="추가"
            android:textSize="13sp"
            android:padding="0dp"
            android:backgroundTint="#007AFF"
            android:textColor="#FFFFFF"
            app:cornerRadius="8dp" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#EEEEEE"
        android:layout_marginBottom="15dp" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:id="@+id/layout_speed_dial_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />
    </ScrollView>
</LinearLayout>