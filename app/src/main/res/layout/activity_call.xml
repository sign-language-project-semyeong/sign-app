<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#003366">

    <TextView
        android:id="@+id/tv_call_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:text="상대방 이름"
        android:textColor="#FFFFFF"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_call_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="010-0000-0000"
        android:textColor="#CCCCCC"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_call_name" />

    <GridLayout
        android:id="@+id/grid_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        app:layout_constraintBottom_toTopOf="@+id/btn_hangup"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_call_number">

        <ImageButton
            android:id="@+id/btn_mute"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="15dp"
            android:background="@drawable/selector_call_button"
            android:src="@android:drawable/stat_notify_call_mute" />

        <ImageButton
            android:id="@+id/btn_keypad"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="15dp"
            android:background="@drawable/selector_call_button"
            android:src="@android:drawable/ic_dialog_dialer" />

        <ImageButton
            android:id="@+id/btn_speaker"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="15dp"
            android:background="@drawable/selector_call_button"
            android:src="@drawable/ic_speaker" />

        <ImageButton
            android:id="@+id/btn_record"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="15dp"
            android:background="@drawable/selector_call_button"
            android:src="@android:drawable/ic_menu_save" />

        <ImageButton
            android:id="@+id/btn_bluetooth"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="15dp"
            android:background="@drawable/selector_call_button"
            android:src="@android:drawable/stat_sys_data_bluetooth" />

        <ImageButton
            android:id="@+id/btn_video"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_margin="15dp"
            android:background="@drawable/selector_call_button"
            android:src="@drawable/baseline_videocam_24"
            android:tint="#ffffff"/>
    </GridLayout>


    <ImageButton
        android:id="@+id/btn_hangup"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="60dp"
        android:background="@drawable/bg_circle_red"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <FrameLayout
        android:id="@+id/layout_dialpad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#000000"
        android:visibility="gone"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:rowCount="4">

            <Button android:id="@+id/btn_1" style="@style/Widget.AppCompat.Button.Borderless" android:text="1" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_2" style="@style/Widget.AppCompat.Button.Borderless" android:text="2" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_3" style="@style/Widget.AppCompat.Button.Borderless" android:text="3" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>

            <Button android:id="@+id/btn_4" style="@style/Widget.AppCompat.Button.Borderless" android:text="4" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_5" style="@style/Widget.AppCompat.Button.Borderless" android:text="5" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_6" style="@style/Widget.AppCompat.Button.Borderless" android:text="6" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>

            <Button android:id="@+id/btn_7" style="@style/Widget.AppCompat.Button.Borderless" android:text="7" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_8" style="@style/Widget.AppCompat.Button.Borderless" android:text="8" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_9" style="@style/Widget.AppCompat.Button.Borderless" android:text="9" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>

            <Button android:id="@+id/btn_star" style="@style/Widget.AppCompat.Button.Borderless" android:text="*" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_0" style="@style/Widget.AppCompat.Button.Borderless" android:text="0" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>
            <Button android:id="@+id/btn_pound" style="@style/Widget.AppCompat.Button.Borderless" android:text="#" android:textColor="#FFFFFF" android:textSize="24sp" android:layout_columnWeight="1"/>

        </GridLayout>
    </FrameLayout>

    <Chronometer
        android:id="@+id/chronometer_call_time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_call_number" />

</androidx.constraintlayout.widget.ConstraintLayout>